#! /usr/bin/env perl
use warnings;
use strict;

use Getopt::Long qw(:config bundling no_ignore_case no_auto_abbrev require_order);
use HTTP::Tiny;
use JSON::XS;
use QBitcoin::Const;
use QBitcoin::Config qw($config read_config);

my $JSON = JSON::XS->new;

sub main {
    my ( $help, $conffile );
    my %opts;
    unless (GetOptions(
        'help|h|?'   => \$help,
        'config|f=s' => \$conffile,
        'rpc|J=s'    => \$opts{rpc},
        'rpc-port=s' => \$opts{rpc_port},
        'testnet|t'  => \$opts{testnet},
    )) {
        select STDERR;
        usage();
        return 1;
    }
    if ($help || !@ARGV) {
        usage();
        return 0;
    }
    read_config($conffile);
    $config->set($_ => $opts{$_}) foreach grep { defined $opts{$_} } keys %opts;
    my $command = shift @ARGV;
    # Read the password from stdin (instead of argv) when it is not given on the
    # command line, so it does not leak into the process list or shell history.
    if ($command && $command eq 'setwalletpassword' && !@ARGV) {
        @ARGV = (read_password("New wallet password: "));
    }
    return call_rpc($command, @ARGV);
}

# Read a secret from stdin. On a terminal echo is disabled and the value is asked
# twice for confirmation; on a pipe a single line is read.
sub read_password {
    my ($prompt) = @_;
    if (-t STDIN) { ## no critic (InputOutput::ProhibitInteractiveTest)
        local $| = 1;
        my $echo_off = system("stty", "-echo") == 0;
        my $pass = _prompt_line($prompt, $echo_off);
        if ($echo_off) {
            my $confirm = _prompt_line("Confirm password: ", $echo_off);
            system("stty", "echo");
            if ($pass ne $confirm) {
                print STDERR "Passwords do not match\n";
                exit 1;
            }
        }
        return $pass;
    }
    my $line = <STDIN>;
    defined($line)
        or do { print STDERR "No password provided on stdin\n"; exit 1; };
    $line =~ s/\r?\n?\z//;
    return $line;
}

sub _prompt_line {
    my ($prompt, $echo_off) = @_;
    print STDERR $prompt;
    my $line = <STDIN>;
    print STDERR "\n" if $echo_off; # the user's Enter was not echoed
    if (!defined($line)) {
        system("stty", "echo") if $echo_off;
        print STDERR "Aborted\n";
        exit 1;
    }
    $line =~ s/\r?\n?\z//;
    return $line;
}

sub usage {
    print "QBitcoin Core RPC Client version " . VERSION . "\n";
    print "Usage:  qbitcoin-cli [options] <command> [<params>]\n";
    print "Options:\n";
    print "   -h, -? --help           - print this help message and exit,\n";
    print "   -f, --config <file>     - config file, 'key = value' format (default " . CONFIG_DIR . "/" . CONFIG_NAME . "),\n";
    print "   -J, --rpc <addr[:port]> - request JSON RPC API on <address> and <port> (default " . RPC_ADDR . ":" . RPC_PORT . "),\n";
    print "   -t, --testnet           - run for testnet (default mainnet),\n";
}

sub call_rpc {
    my ($method, @params) = @_;
    my ($address, $port) = split(/:/, $config->{rpc} // RPC_ADDR);
    $port //= $config->{rpc_port} // getservbyname(SERVICE_NAME, 'tcp') // ($config->{testnet} ? RPC_PORT_TESTNET : RPC_PORT);
    $address = RPC_ADDR if $address eq '*';
    my $url = "http://$address:$port";
    my $ua = HTTP::Tiny->new;
    my $response = $ua->post($url, {
        headers => { 'Content-Type' => 'application/json' },
        content => $JSON->encode({
            jsonrpc => 2.0,
            id      => 1,
            method  => $method,
            params  => \@params,
        }),
    });
    my $result = eval { $JSON->decode($response->{content}) };
    if (!$result || (ref($result) eq 'HASH' && $result->{error})) {
        select STDERR;
        my $error = ref($result) eq 'HASH' ? $result->{error} : undef;
        if (ref($error) eq 'HASH') {
            my $message = $error->{message};
            # Be robust: never exit silently if the message is empty - fall back to a
            # scalar result field (if any), then to the HTTP status line.
            if (!defined($message) || $message eq '') {
                $message = defined($result->{result}) && !ref($result->{result})
                    ? $result->{result} : "$response->{status} $response->{reason}";
            }
            if (defined $error->{code}) {
                print "error code: $error->{code}\n";
                print "error message:\n$message\n";
            }
            else {
                print "$message\n";
            }
        }
        elsif (defined($error) && !ref($error)) {
            print "$error\n";
        }
        else {
            print "$response->{status} $response->{reason}\n";
        }
        return 1;
    }
    if (ref($result) eq 'HASH' && defined $result->{result}) {
        if (ref($result->{result})) {
            print $JSON->pretty->canonical->encode($result->{result});
        }
        else {
            print $result->{result} . "\n";
        }
    }
    return 0;
}

exit main();
